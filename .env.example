# Application Configuration

# Environment
DEBUG=True
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Model Configuration
MODEL_PROVIDER=mediapipe  # mediapipe, hrnet, vibe
CONFIDENCE_THRESHOLD=0.5
MAX_PEOPLE=10

# Device
DEVICE=cuda  # cuda, cpu
GPU_ID=0

# Optimization
USE_ONNX=False
USE_TENSORRT=False
BATCH_SIZE=1

# Image Processing
MAX_IMAGE_SIZE=2048
MIN_IMAGE_SIZE=64

# Output
OUTPUT_SKELETON_THICKNESS=2
OUTPUT_JOINT_RADIUS=4

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]
